<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Must match the host app's App Group so the widget can read the
         payload UserDefaults(suiteName:) written by widgetDataSync. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.nota.npd.com.shareextension</string>
    </array>
</dict>
</plist>
