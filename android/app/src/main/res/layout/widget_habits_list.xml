<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_habits_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_habits_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HABITS"
            android:textColor="#111827"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/widget_habits_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#3c78f0"
            android:textStyle="bold"
            android:textSize="12sp"
            android:text="0 / 0 today" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_habits_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E5E7EB"
        android:dividerHeight="1dp"
        android:listSelector="@android:color/transparent"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/widget_habits_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No habits due today."
        android:textColor="#6B7280"
        android:textSize="13sp" />
</LinearLayout>
