<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/h_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">

    <FrameLayout
        android:id="@+id/h_emoji_bg"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/widget_icon_btn_bg"
        android:layout_marginEnd="12dp">
        <TextView
            android:id="@+id/h_emoji"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="18sp"
            android:text="✨" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/h_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#111827"
            android:textSize="15sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="Habit" />

        <TextView
            android:id="@+id/h_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:text="" />
    </LinearLayout>

    <TextView
        android:id="@+id/h_check"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓"
        android:textColor="#10B981"
        android:textStyle="bold"
        android:textSize="20sp"
        android:visibility="gone"
        android:paddingStart="6dp"
        android:paddingEnd="2dp" />

    <!-- Quick Done button: marks the habit done for today without opening the app. -->
    <TextView
        android:id="@+id/h_action_done"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="34dp"
        android:gravity="center"
        android:text="✓"
        android:textColor="#10B981"
        android:textStyle="bold"
        android:textSize="16sp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/widget_icon_btn_bg"
        android:contentDescription="Mark done" />

    <!-- Quick Skip button: marks today as skipped (preserves streak protections). -->
    <TextView
        android:id="@+id/h_action_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="34dp"
        android:gravity="center"
        android:text="↷"
        android:textColor="#6B7280"
        android:textStyle="bold"
        android:textSize="16sp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/widget_icon_btn_bg"
        android:contentDescription="Skip today" />
</LinearLayout>
