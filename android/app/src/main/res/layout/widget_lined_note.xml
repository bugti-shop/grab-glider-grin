<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_paper"
    android:padding="14dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Title"
        android:textColor="#9CA3AF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <FrameLayout android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="6dp" android:background="#94A3B8" />
    <FrameLayout android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="14dp" android:background="#94A3B8" />
    <FrameLayout android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="14dp" android:background="#94A3B8" />
    <FrameLayout android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="14dp" android:background="#94A3B8" />
    <FrameLayout android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="14dp" android:background="#94A3B8" />
</LinearLayout>